# Agnes AI Platform 后端环境变量示例

# ============================================================
# 【引导配置】Agnes AI API Key（仅首次启动初始化默认 Provider 用）
# 启动后这些值会被写入数据库 api_providers 表，
# 后续在前端配置页（/settings）管理 Provider 和 API Key。
#
# 如果留空，首次启动不会创建默认 Provider，
# 需要手动在前端配置页添加 Provider。
# ============================================================
AGNES_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Agnes AI API 基础地址（仅首次启动初始化默认 Provider 用）
# ============================================================
AGNES_API_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_API_POLL_URL=https://apihub.agnes-ai.com/agnesapi

# ============================================================
# 【重要】API Key 加密密钥
# 用于加密数据库中存储的 Provider API Key（Fernet 对称加密）。
# 生产环境务必配置为随机字符串（建议 32 字符以上）。
# 留空时使用内置默认密钥（仅限开发环境，不安全）。
# 修改此密钥后，已加密的 API Key 将无法解密，需要重新配置 Provider。
# ============================================================
ENCRYPTION_KEY=please-change-this-to-a-random-string

# ============================================================
# 数据库（默认 SQLite，零配置；如需 PostgreSQL 可替换）
# ============================================================
# SQLite（默认）
DATABASE_URL=sqlite:///./agnes_platform.db
# PostgreSQL（可选）
# DATABASE_URL=postgresql://username:password@localhost:5432/agnes_platform

# ============================================================
# CORS - 允许的前端来源（逗号分隔，多值）
# 开发模式下默认 http://localhost:5173
# ============================================================
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# 业务参数（通常无需修改）
# ============================================================
MAX_UPLOAD_SIZE_MB=10
VIDEO_POLL_INTERVAL_SEC=5
VIDEO_POLL_TIMEOUT_SEC=600
